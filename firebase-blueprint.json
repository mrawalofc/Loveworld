{
  "entities": {
    "Message": {
      "title": "Chat Message",
      "description": "A message sent in the real-time chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName", "timestamp", "senderPhoto"]
    },
    "TypingStatus": {
      "title": "Typing Status",
      "description": "Indicates if a user is currently typing",
      "type": "object",
      "properties": {
        "isTyping": { "type": "boolean" },
        "userName": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["isTyping", "lastUpdated"]
    }
  },
  "firestore": {
    "/chat_messages/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages"
    },
    "/typing_status/{userId}": {
      "schema": "TypingStatus",
      "description": "Real-time typing indicators"
    }
  }
}
